# ====================================
# Database Configuration
# ====================================
# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database?sslmode=require
DATABASE_URL="postgresql://username:password@host/database?sslmode=require"

# ====================================
# Authentication (Better Auth)
# ====================================
# Secret key for Better Auth (must be at least 32 characters in production)
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET="your-super-secret-key-at-least-32-characters-long-for-production"

# The URL where your app is hosted
BETTER_AUTH_URL="http://localhost:3000"

# ====================================
# Google OAuth (Optional)
# ====================================
# Get these from: https://console.cloud.google.com/
# Guide: https://authjs.dev/getting-started/providers/google
# The Google button appears automatically when both values are set.
AUTH_GOOGLE_ID="your-google-client-id"
AUTH_GOOGLE_SECRET="your-google-client-secret"

# ====================================
# AI Provider — OpenRouter (Scene 主流程必需)
# ====================================
# OpenRouter (出图 + 场景规划 + 视觉质检 一站式)
# 获取 API Key: https://openrouter.ai/keys
# 单组成本估算（6 张照片，1024px）：~$0.55 / 组
OPENROUTER_API_KEY="sk-or-v1-..."
OPENROUTER_API_URL="https://openrouter.ai/api/v1"
# 出图：Nano Banana 2 (Gemini 3.1 Flash Image Preview)，$0.067/图
OPENROUTER_IMAGE_MODEL="google/gemini-3.1-flash-image-preview"
# 文本（场景规划 / 翻译 / 消歧问答）：Gemini 3.1 Flash Lite Preview，$0.25/M in, $1.50/M out
OPENROUTER_TEXT_MODEL="google/gemini-3.1-flash-lite-preview"
# 视觉（质检 / 组一致性 / 身份粗判）：同上模型
OPENROUTER_VISION_MODEL="google/gemini-3.1-flash-lite-preview"
# 出图 prompt 中追加的画幅指引（Gemini image preview 没有原生 size 字段，靠 prompt 引导）
OPENROUTER_IMAGE_SIZE="1024px portrait 4:5"
# 出图并发：默认 6 张一批并发；429 限流时可降到 3
# SCENE_FRAME_CONCURRENCY="6"
# reference chaining：先串行出第1帧作"组内视觉锚"，其余帧带它做参考并发出图，
# 大幅提升 outfit 颜色 / 配饰位置 / 座椅(anchor 内饰)色的组内一致性（代价：总耗时多一个单帧）。
# 默认开；想要纯并发最快模式设 false
SCENE_REFERENCE_CHAINING="true"

# ====================================
# Email Service (Required for email features)
# ====================================
# Resend API for transactional emails
# Get your API key from: https://resend.com
RESEND_API_KEY="re_your_api_key"

# Email Configuration
# Format: "Display Name <local-part@verified-domain>"
# - Domain must be Verified in Resend dashboard (DKIM/SPF/DMARC all green)
# - hello@ is recommended over noreply@ (allows replies, fewer spam triggers)
RESEND_FROM_EMAIL="SceneSelf <hello@sceneself.com>"

# Optional: Resend Audience ID for newsletter/marketing
RESEND_AUDIENCE_ID="your-resend-audience-id"

# ====================================
# Analytics & Monitoring (Optional)
# ====================================
# Posthog Analytics
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST=""

# Google Analytics
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=""

# Microsoft Clarity
NEXT_PUBLIC_CLARITY_PROJECT_ID=""

# Analytics Feature Flags（可选）
NEXT_PUBLIC_ANALYTICS_ENABLE_IN_DEVELOPMENT=""

# ====================================
# Application Settings
# ====================================
# Public app URL (update in production)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Basic auth for SceneSelf cron callbacks
CRON_JOBS_USERNAME="your_username"
CRON_JOBS_PASSWORD="your_password"
# Optional bearer token if you prefer header-based auth
CRON_SECRET="set-a-strong-cron-secret"

# Node environment
NODE_ENV="development"

# ====================================
# Payments (Creem)
# ====================================
# Get your API key and configure webhook endpoint in Creem dashboard
CREEM_API_KEY="your-creem-api-key"
CREEM_WEBHOOK_SECRET="whsec_..."
# Optional overrides (use if your Creem test environment uses a different domain/path)
CREEM_API_BASE="https://api.creem.io"
# CREEM_CHECKOUT_PATH="/v1/checkout/sessions"
# Set to true to simulate checkout redirect (no external call). In this mode, checkout will redirect to /dashboard?success=1
# CREEM_SIMULATE="false"
# Webhook endpoint to configure in Creem dashboard (for reference):
#   https://your-domain.com/api/payments/creem/webhook

# ====================================
# Feature Flags (Optional)
# ====================================
# Enable/disable features
NEXT_PUBLIC_MAINTENANCE_MODE="false"

# ====================================
# Storage (Optional)
# ====================================
STORAGE_REGION="your-region"
STORAGE_BUCKET_NAME="your-bucket"
STORAGE_ACCESS_KEY_ID="your-access-key"
STORAGE_SECRET_ACCESS_KEY="your-secret-key"
STORAGE_ENDPOINT="https://example.r2.cloudflarestorage.com"
STORAGE_PUBLIC_URL="https://example.com"

# ====================================
# SceneSelf (AI 场景照片集生成器) 调优参数
# ====================================
# Prompt 审核 provider：local（开发/内测）| llm（Gemini）| creem（Creem live payments 前必须切）
PROMPT_MODERATION_PROVIDER="local"
# 质量阈值（上线前用目标市场多族裔样张校准）
QUALITY_MIN="3"
SET_QUALITY_MIN="3"
IDENTITY_THRESHOLD="0.6"
# 每个不合格帧最多重抽候选数
SCENE_MAX_CANDIDATES="1"
# dropped 帧用 passed 帧作 reference 救援的次数
SCENE_RESCUE_ATTEMPTS="2"
# 自拍最长保留小时数（之后清理 selfie_url + identity_ref）
SELFIE_RETENTION_HOURS="24"
# 无 OpenRouter key 时出图返回占位图，让前端流程可演示（dev；有 key 时自动走真实出图）
SCENE_DEV_FALLBACK="true"
